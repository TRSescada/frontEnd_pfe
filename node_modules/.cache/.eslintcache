github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/HEAD/docs/rules/anchor-is-valid.md","JSXOpeningElement",["382"],["383"],"react-hooks/rules-of-hooks","React Hook \"useState\" is called in function \"forgetPage\" that is neither a React function component nor a custom React Hook function. React component names must start with an uppercase letter. React Hook names must start with the word \"use\".","React Hook \"useRef\" is called in function \"forgetPage\" that is neither a React function component nor a custom React Hook function. React component names must start with an uppercase letter. React Hook names must start with the word \"use\".","The href attribute is required for an anchor to be keyboard accessible. Provide a valid, navigable address as the href value. If you cannot provide an href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/HEAD/docs/rules/anchor-is-valid.md",["382"],["383"],"'setSocialLinks' is assigned a value but never used.","'categoryService' is defined but never used.","'setWaiterInfo' is assigned a value but never used.",["385"],"'setComments' is assigned a value but never used.","'setWorkHistory' is assigned a value but never used.","'updateSocialLinks' is assigned a value but never used.","'changeWorkPlace' is assigned a value but never used.","'changeWorkerStatus' is assigned a value but never used.","'setVisitorInfo' is assigned a value but never used.","'setRestaurantCardData' is assigned a value but never used.","'setMenuCategories' is assigned a value but never used.","'setEmployees' is assigned a value but never used.","'setRestaurants' is assigned a value but never used.","'setMyRestaurants' is assigned a value but never used.","'setManagers' is assigned a value but never used.","'setManagerInfo' is assigned a value but never used.","'setRestaurantData' is assigned a value but never used.","'setTables' is assigned a value but never used.","'setGroups' is assigned a value but never used.","React Hook useEffect has a missing dependency: 'generateInvoice'. Either include it or remove the dependency array.",["386"],"'waiterInfoFromMenu' is assigned a value but never used.","'history' is assigned a value but never used.","React Hook useEffect has missing dependencies: 'employeesData', 'employeesWorkHistory', and 'workerInfo'. Either include them or remove the dependency array. You can also do a functional update 'setWorkerInfo(w => ...)' if you only need 'workerInfo' in the 'setWorkerInfo' call.",["387"],"'setOwners' is assigned a value but never used.","'openOwnerModal' is assigned a value but never used.","React Hook useEffect has a missing dependency: 'ownersData'. Either include it or remove the dependency array.",["388"],["389"],["390"],"no-global-assign","no-unsafe-negation",{"desc":"391","fix":"392"},{"desc":"393","fix":"394"},{"desc":"395","fix":"396"},{"desc":"397","fix":"398"},{"desc":"399","fix":"400"},{"desc":"391","fix":"401"},{"desc":"391","fix":"402"},"Update the dependencies array to be: [isAnyHovered, texts.length]",{"range":"403","text":"404"},"Update the dependencies array to be: [showProducts, texts.length]",{"range":"405","text":"406"},"Update the dependencies array to be: [generateInvoice]",{"range":"407","text":"408"},"Update the dependencies array to be: [id, employeeFromList, employeesData, workerInfo, employeesWorkHistory]",{"range":"409","text":"410"},"Update the dependencies array to be: [ownerId, ownersData, restaurantId]",{"range":"411","text":"412"},{"range":"413","text":"404"},{"range":"414","text":"404"},[1313,1327],"[isAnyHovered, texts.length]",[7362,7376],"[showProducts, texts.length]",[8219,8221],"[generateInvoice]",[5850,5872],"[id, employeeFromList, employeesData, workerInfo, employeesWorkHistory]",[2362,2385],"[ownerId, ownersData, restaurantId]",[1353,1367],[1350,1364]]